# =====================================================================
# OwnCord — пример конфига nginx (reverse proxy + TLS).
#
# Использование:
#   1. Скопируй в /etc/nginx/sites-available/owncord и подкорректируй
#      server_name и путь к сертификатам.
#   2. ln -s /etc/nginx/sites-available/owncord /etc/nginx/sites-enabled/
#   3. nginx -t && systemctl reload nginx
#
# Сертификаты удобно получить через certbot:
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d owncord.example.com
#
# WebRTC голос/видео работают P2P (через STUN/TURN), nginx их не проксирует —
# он отвечает только за HTTP API + WebSocket для сигналинга/чата.
# =====================================================================

# --- Редирект HTTP → HTTPS ------------------------------------------
server {
  listen 80;
  listen [::]:80;
  server_name owncord.example.com;

  # ACME challenge оставляем отдельно (если используешь webroot mode).
  location /.well-known/acme-challenge/ { root /var/www/letsencrypt; }

  location / {
    return 301 https://$host$request_uri;
  }
}

# --- HTTPS ----------------------------------------------------------
server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name owncord.example.com;

  ssl_certificate     /etc/letsencrypt/live/owncord.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/owncord.example.com/privkey.pem;
  ssl_protocols       TLSv1.2 TLSv1.3;
  ssl_ciphers         HIGH:!aNULL:!MD5;
  ssl_session_cache   shared:SSL:10m;

  # Загрузки до 500 МБ — поднимаем под лимит сервера (см. MAX_UPLOAD_MB).
  # Если поднял MAX_UPLOAD_MB на сервере — синхронно подними и тут.
  client_max_body_size 600m;

  # Чтобы аплоады голосовых/файлов не отваливались по таймауту.
  proxy_read_timeout  3600s;
  proxy_send_timeout  3600s;
  send_timeout        3600s;

  # Вариант А: nginx отдаёт фронт сам (быстрее, кешируется).
  # Если фронт собирается в client/dist и доступен по /var/www/owncord/dist,
  # раскомментируй блок ниже и закомментируй `proxy_pass` ниже для location /.
  #
  # root /var/www/owncord/dist;
  # location / {
  #   try_files $uri $uri/ /index.html;
  # }
  # location /assets/ {
  #   expires 7d;
  #   add_header Cache-Control "public, max-age=604800, immutable";
  # }

  # Вариант B (по-умолчанию): node-сервер сам отдаёт собранный фронт.
  # Это самый простой путь — ничего не надо синхронизировать вручную.

  # --- Socket.IO (WebSocket) -----------------------------------------
  location /socket.io/ {
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://127.0.0.1:3001;

    proxy_buffering off;
    proxy_read_timeout 3600s;
  }

  # --- Авто-обновление десктоп-клиента ------------------------------
  # latest.yml + OwnCord Setup *.exe + *.blockmap раздаются как статика.
  # electron-updater на стороне клиента качает их напрямую через nginx,
  # минуя node — это разгружает app-сервер от 80MB-блобов.
  # Папка на диске (по умолчанию /var/www/owncord-updates) должна быть
  # доступна на запись юзеру, который делает релизы (см. deploy/UPDATES.md).
  location /updates/ {
    alias /var/www/owncord-updates/;
    autoindex off;
    add_header X-Content-Type-Options "nosniff" always;

    # Вложенные location'ы наследуют alias родителя, так что повторять
    # его не нужно — nginx сам подставит /var/www/owncord-updates/<file>.

    # latest.yml НЕ кешируем — иначе клиенты будут «видеть» старую
    # версию ещё долго после релиза.
    location ~* \.ya?ml$ {
      add_header Cache-Control "no-cache, must-revalidate" always;
      add_header X-Content-Type-Options "nosniff" always;
    }

    # .exe и .blockmap immutable по версии (имя файла содержит версию),
    # их можно кешировать на день — экономит трафик при retry'ах.
    location ~* \.(exe|blockmap)$ {
      expires 1d;
      add_header Cache-Control "public, max-age=86400, immutable" always;
      add_header X-Content-Type-Options "nosniff" always;
    }
  }

  # --- Загрузки/раздача файлов (стримим, не буферизуем) -------------
  # Для больших файлов (видео, голосовые до 500 МБ) важно отключить
  # буферизацию: иначе nginx складывает запрос на диск/в RAM целиком,
  # прежде чем начать передавать его в node, что съедает IOPS и
  # задерживает старт ответа клиенту.
  location /uploads/ {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://127.0.0.1:3001;

    proxy_buffering off;
    proxy_request_buffering off;
    # nosniff на статике — страховка от XSS, если magic-bytes sniffing
    # на сервере по какой-то причине пропустит подделку MIME.
    add_header X-Content-Type-Options "nosniff" always;
  }

  # --- API + статика клиента (вариант B) ----------------------------
  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_pass http://127.0.0.1:3001;
  }

  # gzip уже включён глобально в большинстве дистрибутивов; если нет —
  # раскомментируй:
  # gzip on;
  # gzip_types text/plain text/css application/javascript application/json;
}
