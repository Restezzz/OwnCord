# Copy to /etc/owncord-notify.env (root:root, mode 0640) and fill in.
# Without this file owncord-notify.sh silently no-ops.

# Bot token issued by @BotFather.
TG_BOT_TOKEN=

# Chat ID(s) where alerts go (negative for groups/channels).
# Comma-separated list — message will be sent to each.
# Example: TG_CHAT_ID=-5257014987,991727781
TG_CHAT_ID=

# Optional HTTPS proxy if api.telegram.org is blocked from this host.
# TG_PROXY=http://172.21.0.1:7890
