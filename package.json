{
  "name": "owncord",
  "version": "0.7.2",
  "private": true,
  "description": "Self-hosted minimal messenger with voice/video calls and screen sharing",
  "license": "MIT",
  "author": "Restez",
  "repository": {
    "type": "git",
    "url": "https://github.com/Restezzz/OwnCord.git"
  },
  "homepage": "https://github.com/Restezzz/OwnCord#readme",
  "bugs": {
    "url": "https://github.com/Restezzz/OwnCord/issues"
  },
  "workspaces": [
    "server",
    "client",
    "desktop"
  ],
  "scripts": {
    "install:all": "npm install && npm --workspace server install && npm --workspace client install && npm --workspace desktop install",
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server start",
    "desktop": "npm --workspace desktop run start",
    "desktop:dev": "cross-env OWNCORD_SERVER_URL=http://localhost:5173 npm --workspace desktop run start",
    "desktop:build": "npm --workspace desktop run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.2"
  }
}
