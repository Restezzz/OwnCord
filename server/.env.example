# =====================================================================
# OwnCord server config. Скопируй этот файл в server/.env и поправь.
# =====================================================================

# HTTP-порт. Если поднимаешь за nginx — оставь 3001.
PORT=3001

# Секрет для подписи JWT-токенов. ОБЯЗАТЕЛЬНО смени на длинную случайную
# строку (например: openssl rand -hex 48). При смене все пользователи
# вылогинятся — это нормально.
JWT_SECRET=change-me-please-to-a-long-random-string

# --- Регистрация ----------------------------------------------------
# Если REGISTRATION_CODE задан — клиент должен прислать ровно эту строку
# при регистрации. Раздавай код только доверенным людям. Можно ротировать
# в любой момент: обновляй .env и перезапускай сервер.
# Закомментируй / оставь пустым — регистрация открыта без кода.
# REGISTRATION_CODE=ourSecretCode2025

# Полностью закрыть регистрацию (например, когда все нужные пользователи
# уже создали аккаунты). Принимаемые значения: 1, true, yes.
# REGISTRATION_DISABLED=1

# Список username'ов, которые считаются администраторами. Им доступна
# вкладка «Приглашения» в настройках, где можно выпускать одноразовые/
# multi-use коды без перезапуска сервера. CSV, регистр не важен.
# Если переменная не задана, админом считается пользователь с id=1
# (т.е. первый зарегистрированный). На большинстве маленьких инсталляций
# этого достаточно.
# ADMIN_USERNAMES=alice,bob

# --- Загрузки -------------------------------------------------------
# Максимальный размер одного файла в мегабайтах.
# По умолчанию 500 (см. server/src/uploads.js).
# MAX_UPLOAD_MB=500

# --- Ретеншн истории ------------------------------------------------
# Сколько дней хранятся сообщения/вложения в БД и на диске. Всё, что
# старше, чистится раз в час фоновой задачей. По умолчанию 90 дней.
# RETENTION_DAYS=90

# --- Web Push (опционально) ----------------------------------------
# При первом старте сервер сам генерирует VAPID-пару и сохраняет в
# server/data/vapid.json — настраивать руками не обязательно. Если
# хочется задать ключи фиксированно (например, при миграции на новый
# сервер с уже подписанными клиентами), пропиши их здесь:
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@example.com

# --- TURN (опционально) --------------------------------------------
# По умолчанию используется только публичный STUN от Google. Этого хватает
# в ~80% случаев. Если у пользователей строгий NAT (corporate, мобильные
# CGNAT), голос/видео могут не подключаться — тогда нужен TURN.
# Подними coturn рядом и подставь URL+креды:
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=owncord
# TURN_PASSWORD=replace-me
