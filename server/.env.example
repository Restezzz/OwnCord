# =====================================================================
# OwnCord server config. Скопируй этот файл в server/.env и поправь.
# =====================================================================

# HTTP-порт. Если поднимаешь за nginx — оставь 3001.
PORT=3001

# В production NODE_ENV=production обязателен — он включает строгий CSP,
# отключает CORS-вседозволенность и заставляет сервер падать на старте,
# если JWT_SECRET слабый/не задан. systemd-юнит из deploy/ его выставляет.
# NODE_ENV=production

# Секрет для подписи JWT-токенов. ОБЯЗАТЕЛЬНО смени на длинную случайную
# строку (например: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))").
# В production сервер откажется стартовать без секрета >= 16 символов.
# При смене все пользователи вылогинятся — это нормально.
JWT_SECRET=change-me-please-to-a-long-random-string

# Срок жизни токена. По умолчанию `never` — токен не истекает, юзер
# остаётся залогинен пока сам не выйдет (UX-приоритет, особенно для
# десктоп-клиента). При компрометации секрета ротируй JWT_SECRET —
# это инвалидирует все выданные токены за один шаг.
#
# Если хочется поведение прежних версий (14 дней), раскомментируй ниже.
# Формат — любой, который понимает jsonwebtoken: '7d', '24h', '30m'.
# Спец. значения 'never' | 'none' | '0' = без срока.
# JWT_TTL=14d

# --- CORS / разрешённые домены --------------------------------------
# Список фронтенд-доменов через запятую, которым разрешено стучаться
# в API и подключаться к WebSocket. Если переменная не задана:
#  - в dev (NODE_ENV != production) — разрешены все origin'ы (удобно);
#  - в production — все кросс-доменные запросы блокируются.
# Same-origin (фронт раздаётся с того же сервера, что и бэкенд) работает
# в любом случае без явного APP_ORIGIN.
# APP_ORIGIN=https://owncord.example.com

# --- Регистрация ----------------------------------------------------
# Если REGISTRATION_CODE задан — клиент должен прислать ровно эту строку
# при регистрации. Раздавай код только доверенным людям. Можно ротировать
# в любой момент: обновляй .env и перезапускай сервер.
# Закомментируй / оставь пустым — регистрация открыта без кода.
# REGISTRATION_CODE=ourSecretCode2025

# Полностью закрыть регистрацию (например, когда все нужные пользователи
# уже создали аккаунты). Принимаемые значения: 1, true, yes.
# REGISTRATION_DISABLED=1

# Список username'ов, которые считаются администраторами. Им доступна
# вкладка «Приглашения» в настройках, где можно выпускать одноразовые/
# multi-use коды без перезапуска сервера. CSV, регистр не важен.
# Если переменная не задана, админом считается пользователь с id=1
# (т.е. первый зарегистрированный). На большинстве маленьких инсталляций
# этого достаточно.
# ADMIN_USERNAMES=alice,bob

# --- Загрузки -------------------------------------------------------
# Максимальный размер одного файла в мегабайтах.
# По умолчанию 500 (см. server/src/uploads.js).
# MAX_UPLOAD_MB=500

# --- Ретеншн истории ------------------------------------------------
# Сколько дней хранятся сообщения/вложения в БД и на диске. Всё, что
# старше, чистится раз в час фоновой задачей. По умолчанию 90 дней.
# RETENTION_DAYS=90

# --- Web Push (опционально) ----------------------------------------
# При первом старте сервер сам генерирует VAPID-пару и сохраняет в
# server/data/vapid.json — настраивать руками не обязательно. Если
# хочется задать ключи фиксированно (например, при миграции на новый
# сервер с уже подписанными клиентами), пропиши их здесь:
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:admin@example.com

# --- 152-ФЗ / Privacy (опционально) --------------------------------
# Если разворачиваешь сервер на домене в зонах .ru/.рф/.su и пользователи
# не только ты сам — формально нужен оператор ПДн и страница политики.
# Заполни оба поля ниже, чтобы на сервере появилась страница /privacy и
# на странице регистрации — ссылка на неё. Если поля пустые, модуль
# выключен и ничего не рендерится.
# PRIVACY_OPERATOR_NAME="ИП Иванов Иван Иванович"
# PRIVACY_OPERATOR_EMAIL=privacy@owncord.example.com
# PRIVACY_OPERATOR_ADDRESS="г. Москва, ул. Примерная, 1"
# Дата последней редакции (опц.; иначе берётся текущая на момент рендера).
# PRIVACY_LAST_UPDATED=2026-04-29
# Требовать чекбокс согласия при регистрации (1/true/yes). Имеет смысл
# включать только если PRIVACY_OPERATOR_NAME+EMAIL заданы. Время согласия
# сохраняется в users.privacy_consent_at для compliance-аудита.
# REQUIRE_PRIVACY_CONSENT=1

# --- TURN (опционально) --------------------------------------------
# По умолчанию используется только публичный STUN от Google. Этого хватает
# в ~80% случаев. Если у пользователей строгий NAT (corporate, мобильные
# CGNAT), голос/видео могут не подключаться — тогда нужен TURN.
# Подними coturn рядом и подставь URL+креды:
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=owncord
# TURN_PASSWORD=replace-me
